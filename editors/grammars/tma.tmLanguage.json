{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TMA",
  "comment": "TM-1 .tma assembly (docs/formats.md). Mnemonics mirror tm1_syntax() in crates/turing-machine/src/asm/mod.rs; the drift guard in crates/turing-machine/tests/editor_grammar.rs asserts coverage GENERATED from that table, so a new mnemonic fails the test until the alternation catches up. The alternation is ordered longest-first: a dotted form (call.m, call.s) must precede its bare prefix, since `.` is not a word character and a trailing \\b would otherwise let `call` win. Directives are checked in the other direction — the guard assembles each one the grammar lists and asserts the assembler does not reject it as an unknown mnemonic. Labels use the pragmatic ASCII class [A-Za-z_][A-Za-z0-9_]* for highlighting even though the assembler additionally accepts Unicode letters — best-effort, not a full identifier class.",
  "scopeName": "source.tma",
  "patterns": [
    { "include": "#comments" },
    { "include": "#sectionDirective" },
    { "include": "#funcDirective" },
    { "include": "#routineDirective" },
    { "include": "#repeatDirective" },
    { "include": "#tableDirective" },
    { "include": "#frameDirective" },
    { "include": "#byteDirective" },
    { "include": "#label" },
    { "include": "#mnemonics" },
    { "include": "#interpolation" },
    { "include": "#operators" },
    { "include": "#wildcard" },
    { "include": "#symbol" },
    { "include": "#number" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.semicolon.tma", "match": ";.*$" }]
    },
    "sectionDirective": {
      "match": "(\\.section)\\b\\s*([A-Za-z_][A-Za-z0-9_]*)?",
      "captures": {
        "1": { "name": "keyword.control.directive.tma" },
        "2": { "name": "entity.name.section.tma" }
      }
    },
    "funcDirective": {
      "match": "(\\.func)\\b\\s+([A-Za-z_][A-Za-z0-9_.:]*)(?:\\s+(local)\\b)?",
      "captures": {
        "1": { "name": "keyword.control.directive.tma" },
        "2": { "name": "entity.name.function.tma" },
        "3": { "name": "storage.modifier.tma" }
      }
    },
    "routineDirective": {
      "match": "(\\.routine)\\b\\s*([A-Za-z_][A-Za-z0-9_.:]*)?",
      "captures": {
        "1": { "name": "keyword.control.directive.tma" },
        "2": { "name": "entity.name.function.tma" }
      }
    },
    "repeatDirective": {
      "name": "keyword.control.directive.tma",
      "match": "\\.(rept|endr)\\b"
    },
    "tableDirective": {
      "name": "keyword.control.directive.tma",
      "match": "\\.(row|targets|target)\\b"
    },
    "frameDirective": {
      "name": "keyword.control.directive.tma",
      "match": "\\.(frame|map|exits)\\b"
    },
    "byteDirective": {
      "name": "keyword.control.directive.tma",
      "match": "\\.byte\\b"
    },
    "mnemonics": {
      "name": "keyword.other.mnemonic.tma",
      "match": "\\b(call\\.m|call\\.s|wrmv|djmp|retx|trap|call|jmp|jnm|brk|ent|hlt|mov|mtc|nop|ret|stp|rd|jm|wr)\\b"
    },
    "label": {
      "match": "^[ \\t]*([A-Za-z_][A-Za-z0-9_]*)(:)",
      "captures": {
        "1": { "name": "entity.name.label.tma" },
        "2": { "name": "punctuation.separator.label.tma" }
      }
    },
    "interpolation": {
      "comment": "A `.rept` variable substitution, e.g. Linc{v} or [*,{v},*,*].",
      "name": "meta.embedded.expression.tma",
      "match": "\\{[^}\\n]*\\}"
    },
    "wildcard": {
      "patterns": [
        { "name": "constant.language.wildcard.tma", "match": "(?<![A-Za-z0-9_])\\*(?![A-Za-z0-9_])" },
        { "name": "keyword.operator.move.tma", "match": "(?<![A-Za-z0-9_])[<>](?![A-Za-z0-9_=])" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.map.tma", "match": "->|=>" },
        { "name": "keyword.operator.frame.tma", "match": "#" },
        { "name": "keyword.operator.assignment.tma", "match": "=" }
      ]
    },
    "symbol": {
      "name": "variable.other.symbol.tma",
      "match": "@[A-Za-z_][\\w.:]*"
    },
    "number": {
      "name": "constant.numeric.tma",
      "match": "-?\\b(?:0x[0-9A-Fa-f]+|\\d+)\\b"
    }
  }
}
